{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(uv *)",
      "Bash(uv run *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip-audit*)",
      "Bash(pre-commit *)",
      "Bash(uv run pre-commit*)"
    ],

    "deny": [
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(python -m pip install*)",
      "Bash(python3 -m pip install*)"
    ]
  }
}
